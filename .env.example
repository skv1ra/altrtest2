# Public application URL. Use http://localhost:3000 locally and the canonical
# production URL in Vercel.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public Supabase client configuration.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Compatibility value for legacy server-only billing readers. Keep it equal to
# NEXT_PUBLIC_SUPABASE_URL until those readers are retired.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Server-only Supabase credential. Never prefix this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Lemon Squeezy server configuration.
LEMONSQUEEZY_API_KEY=YOUR_LEMONSQUEEZY_API_KEY
LEMONSQUEEZY_STORE_ID=YOUR_LEMONSQUEEZY_STORE_ID
LEMONSQUEEZY_WEBHOOK_SECRET=YOUR_LEMONSQUEEZY_WEBHOOK_SECRET
LEMONSQUEEZY_PERSONAL_VARIANT_ID=YOUR_PERSONAL_VARIANT_ID
LEMONSQUEEZY_WORK_VARIANT_ID=YOUR_WORK_VARIANT_ID

# Optional integrations.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
RESEND_API_KEY=YOUR_RESEND_API_KEY
BILLING_EMAIL_FROM=Altr <billing@example.com>
